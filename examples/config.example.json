{
  "security_profile": "hardened",
  "address": "127.0.0.1:8765",
  "agent_unix_socket": "/tmp/promptlock-agent.sock",
  "operator_unix_socket": "/tmp/promptlock-operator.sock",
  "audit_path": "/var/log/promptlock/audit.jsonl",
  "state_store_file": "/var/lib/promptlock/state-store.json",
  "state_store": {
    "type": "file"
  },
  "policy": {
    "default_ttl_minutes": 5,
    "min_ttl_minutes": 1,
    "max_ttl_minutes": 30,
    "max_secrets_per_request": 5
  },
  "auth": {
    "enable_auth": true,
    "operator_token": "CHANGE_ME_OPERATOR_TOKEN",
    "allow_plaintext_secret_return": false,
    "session_ttl_minutes": 10,
    "grant_idle_timeout_minutes": 480,
    "grant_absolute_max_minutes": 10080,
    "bootstrap_token_ttl_seconds": 60,
    "cleanup_interval_seconds": 60,
    "rate_limit_window_seconds": 60,
    "rate_limit_max_attempts": 20,
    "store_file": "/var/lib/promptlock/auth-store.json",
    "store_encryption_key_env": "PROMPTLOCK_AUTH_STORE_KEY"
  },
  "execution_policy": {
    "exact_match_executables": ["npm", "node", "go", "python", "pytest", "make", "git"],
    "denylist_substrings": ["printenv", "/proc/", "environ"],
    "output_security_mode": "none",
    "max_output_bytes": 65536,
    "default_timeout_sec": 120,
    "max_timeout_sec": 600
  },
  "host_ops_policy": {
    "docker_allow_subcommands": ["version", "ps", "images", "compose"],
    "docker_compose_allow_verbs": ["config", "ps"],
    "docker_ps_allowed_flags": ["-a", "--all", "-q", "--quiet", "--format", "-f", "--filter", "--no-trunc", "-n", "--last"],
    "docker_images_allowed_flags": ["-q", "--quiet", "--format", "--no-trunc", "--digests", "--filter"],
    "docker_deny_substrings": ["--privileged", "--pid=host", "-v /:/", "docker.sock", "--network host", "--mount", "-v "],
    "docker_timeout_sec": 30
  },
  "network_egress_policy": {
    "enabled": true,
    "require_intent_match": true,
    "allow_domains": ["api.github.com", "registry.npmjs.org", "pypi.org"],
    "intent_allow_domains": {
      "run_tests": ["api.github.com"],
      "install_deps": ["registry.npmjs.org", "pypi.org"]
    },
    "deny_substrings": ["169.254.169.254", "metadata.google.internal", "localhost", "127.0.0.1"]
  },
  "secret_source": {
    "type": "env",
    "env_prefix": "PROMPTLOCK_SECRET_",
    "in_memory_hardened": "fail"
  },
  "secrets": [],
  "intents": {
    "run_tests": ["github_token"],
    "publish_npm": ["npm_token"],
    "run_e2e": ["github_token", "npm_token"]
  }
}
